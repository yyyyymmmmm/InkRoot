<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/inkroot_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/inkroot_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/inkroot_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="快速记录"
            android:textColor="@color/inkroot_widget_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/inkroot_widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="今日 0 条"
            android:textColor="@color/inkroot_widget_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/inkroot_widget_quick_note"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/inkroot_widget_primary_button"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="+ 写一条"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/inkroot_widget_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/inkroot_widget_tag_1"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/inkroot_widget_chip"
            android:ellipsize="end"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="#灵感"
            android:textColor="@color/inkroot_primary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/inkroot_widget_tag_2"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/inkroot_widget_chip"
            android:ellipsize="end"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="#工作"
            android:textColor="@color/inkroot_primary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/inkroot_widget_tag_3"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:background="@drawable/inkroot_widget_chip"
            android:ellipsize="end"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="#日记"
            android:textColor="@color/inkroot_primary"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/inkroot_widget_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="静待沉淀，蓄势而鸣"
        android:textColor="@color/inkroot_widget_muted"
        android:textSize="11sp" />
</LinearLayout>
