<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/inkroot_widget_review_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/inkroot_widget_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/inkroot_widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="随机回顾"
            android:textColor="@color/inkroot_widget_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/inkroot_widget_random"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/inkroot_widget_chip"
            android:gravity="center"
            android:includeFontPadding="false"
            android:minWidth="56dp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:text="打开"
            android:textColor="@color/inkroot_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/inkroot_widget_review"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:lineSpacingExtra="2dp"
        android:maxLines="5"
        android:text="打开 InkRoot 后显示随机回顾"
        android:textColor="@color/inkroot_widget_text"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/inkroot_widget_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="1小时刷新 · 全部"
        android:textColor="@color/inkroot_widget_muted"
        android:textSize="11sp" />
</LinearLayout>
