# Memos API 测试环境配置文件
# 复制此文件为 .env 并填写实际配置

# ============================================
# Docker 本地测试环境（7个主版本完整覆盖）
# ============================================

# v0.21.0 测试服务器（基线版本）
MEMOS_V21_BASE_URL=http://localhost:5230
MEMOS_V21_USERNAME=testuser
MEMOS_V21_PASSWORD=testpass123

# v0.22.5 测试服务器（API v1 不兼容更新后的稳定版）
MEMOS_V22_BASE_URL=http://localhost:5231
MEMOS_V22_USERNAME=testuser
MEMOS_V22_PASSWORD=testpass123

# v0.23.1 测试服务器（标签重构版本）
MEMOS_V23_BASE_URL=http://localhost:5232
MEMOS_V23_USERNAME=testuser
MEMOS_V23_PASSWORD=testpass123

# v0.24.4 测试服务器（数据库&API变更后的稳定版）
MEMOS_V24_BASE_URL=http://localhost:5233
MEMOS_V24_USERNAME=testuser
MEMOS_V24_PASSWORD=testpass123

# v0.25.3 测试服务器（数据库&API变更后的稳定版）
MEMOS_V25_BASE_URL=http://localhost:5234
MEMOS_V25_USERNAME=testuser
MEMOS_V25_PASSWORD=testpass123

# v0.26.2 测试服务器（Token刷新机制）
MEMOS_V26_BASE_URL=http://localhost:5235
MEMOS_V26_USERNAME=testuser
MEMOS_V26_PASSWORD=testpass123

# v0.27.1 测试服务器（Username路径 + 最新特性）
MEMOS_V27_BASE_URL=http://localhost:5236
MEMOS_V27_USERNAME=testuser
MEMOS_V27_PASSWORD=testpass123

# ============================================
# 生产环境配置示例（请勿提交实际密钥）
# ============================================

# 生产 Memos 服务器
# MEMOS_PROD_BASE_URL=https://memos.your-domain.com
# MEMOS_PROD_USERNAME=your_username
# MEMOS_PROD_PASSWORD=your_secure_password

# ============================================
# 测试选项
# ============================================

# 是否启用详细日志（true/false）
TEST_VERBOSE_LOGGING=true

# 测试超时时间（秒）
TEST_TIMEOUT_SECONDS=30

# 是否跳过需要手动创建用户的测试
TEST_SKIP_USER_SETUP=false

# ============================================
# IntRoot 项目配置（集成测试用）
# ============================================

# IntRoot 使用的 Memos 服务器
INTROOT_MEMOS_BASE_URL=http://localhost:5236
INTROOT_MEMOS_USERNAME=admin
INTROOT_MEMOS_PASSWORD=admin123

# ============================================
# 安全提示
# ============================================
# 1. 请勿将 .env 文件提交到版本控制系统
# 2. 生产环境密码请使用强密码
# 3. 定期轮换 API 密钥
# 4. 测试环境与生产环境严格隔离
